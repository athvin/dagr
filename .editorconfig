# EditorConfig — https://editorconfig.org
# Whitespace/line-ending/charset defaults that mirror rustfmt.toml so an editor
# honoring this file produces output `rustfmt --check` accepts (Test 6). The
# authoritative Rust formatter is still rustfmt; this covers editors and
# non-Rust files.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
# Mirrors rustfmt.toml: tab_spaces = 4, hard_tabs = false, newline_style = Unix.
indent_style = space
indent_size = 4

[*.md]
# Markdown may use trailing spaces as hard line breaks; do not trim.
trim_trailing_whitespace = false

[*.{yml,yaml,toml,json}]
indent_style = space
indent_size = 2
